[
  {
    "name": "sync download noops when already current",
    "seed": {
      "doc.txt": "base\n"
    },
    "clients": ["a"],
    "steps": [
      {"client": "a", "op": "sync_download", "want": {"upserts": 0, "removes": 0, "conflicts": 0}},
      {"client": "a", "op": "assert", "path": "doc.txt", "content": "base\n"}
    ]
  },
  {
    "name": "sync download applies remote create",
    "seed": {
      "anchor.txt": "base\n"
    },
    "clients": ["a", "b"],
    "steps": [
      {"client": "a", "op": "write", "path": "new.txt", "content": "from a\n", "minutes": 10},
      {"client": "a", "op": "index", "memo": "a create"},
      {"client": "a", "op": "sync", "want": {"upserts": 0, "removes": 0, "conflicts": 0}},
      {"client": "b", "op": "sync_download", "want": {"upserts": 1, "removes": 0, "conflicts": 0}},
      {"client": "b", "op": "assert", "path": "anchor.txt", "content": "base\n"},
      {"client": "b", "op": "assert", "path": "new.txt", "content": "from a\n"}
    ]
  },
  {
    "name": "sync download applies remote update",
    "seed": {
      "doc.txt": "base\n"
    },
    "clients": ["a", "b"],
    "steps": [
      {"client": "a", "op": "write", "path": "doc.txt", "content": "from a\n", "minutes": 10},
      {"client": "a", "op": "index", "memo": "a update"},
      {"client": "a", "op": "sync", "want": {"upserts": 0, "removes": 0, "conflicts": 0}},
      {"client": "b", "op": "sync_download", "want": {"upserts": 1, "removes": 0, "conflicts": 0}},
      {"client": "b", "op": "assert", "path": "doc.txt", "content": "from a\n"}
    ]
  },
